clean_long_excel <- function(path) {
raw <- read_excel(path, col_names = FALSE)
# Encabezados por fila (0-index mental):
# Fila 1: "Detección Olfativa" / "Detección temperatura"
# Fila 2: "P8" "P12" "P16" "P20"
# Fila 3: "LATENCIA" "PERMANENCIA" ...
# Fila 4: "FAM" "NOV" ...
h0 <- raw %>% slice(1) %>% unlist(use.names = FALSE)
h1 <- raw %>% slice(2) %>% unlist(use.names = FALSE)
h2 <- raw %>% slice(3) %>% unlist(use.names = FALSE)
h3 <- raw %>% slice(4) %>% unlist(use.names = FALSE)
# Forward-fill horizontal para propagar etiquetas dentro de cada bloque
ff <- function(x) {
out <- x
for (i in seq_along(out)) {
if (is.na(out[i]) && i > 1) out[i] <- out[i-1]
}
out
}
h0 <- ff(h0)
h1 <- ff(h1)
h2 <- ff(h2)
# Construcción de nombres
make_name <- function(i) {
# Columnas 1-4 son metadatos (según tus archivos reales)
if (i == 1) return("ANIMAL")    # a veces dice RATONA
if (i == 2) return("CODIGO")    # p.ej. 902 o "2R"
if (i == 3) return("SEXO")
if (i == 4) return("ID")
parts <- c(h0[i], h1[i], h2[i], h3[i]) %>%
discard(is.na) %>%
as.character() %>%
str_trim() %>%
discard(~ .x == "")
nm <- str_c(parts, collapse = "_") %>%
str_replace_all("\\s+", "_") %>%
str_replace_all("[^[:alnum:]_áéíóúÁÉÍÓÚñÑ]+", "_")
nm
}
new_names <- map_chr(seq_len(ncol(raw)), make_name)
# Datos comienzan en la fila 5 (después de 4 filas de encabezado)
df <- raw %>%
slice(-(1:4)) %>%
setNames(new_names) %>%
filter(!is.na(ID)) %>%
mutate(
# Asegura caracteres limpios
SEXO = as.character(SEXO),
ID   = as.character(ID),
# CONDICION desde ID: si contiene EXP -> EXP, si contiene CTRL -> CTRL
CONDICION = case_when(
str_detect(ID, regex("EXP",  ignore_case = TRUE))  ~ "EXP",
str_detect(ID, regex("CTRL", ignore_case = TRUE))  ~ "CTRL",
TRUE ~ NA_character_
)
)
# Convierte a numérico todo menos metadatos
meta <- c("ANIMAL", "CODIGO", "SEXO", "ID", "CONDICION")
df <- df %>%
mutate(across(setdiff(names(df), meta), ~ suppressWarnings(as.numeric(.x))))
df
}
