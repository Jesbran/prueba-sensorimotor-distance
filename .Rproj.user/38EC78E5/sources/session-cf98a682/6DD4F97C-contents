#################################
# Chinese sensorimotor norms
#################################

norms <- read_excel("SENSORIMOTORNOR_MS_FOR_CHINESE_NOUNS.xlsx")

colnames(norms)

# Cambiar nombre de columna
norms <- norms %>%
  rename(Word_Chinese = Word)

# Cambiar nombre de columna
norms <- norms %>%
  rename(Word = English_translation)

# Poner pimero la columna Word
norms <- norms %>%
  select(Word, everything())

colnames(norms)

# Cambiar nombres de las columnas
norms <- norms %>%
  rename(
    # ===== PERCEPTUAL MEANS =====
    Visual.mean         = visual,
    Auditory.mean       = auditory,
    Gustatory.mean      = gustatory,
    Haptic.mean         = tactile,
    Interoceptive.mean  = interoceptive,
    Olfactory.mean      = olfactory,
    # ===== ACTION MEANS =====
    Foot_leg.mean       = `leg/foot`,
    Hand_arm.mean       = `hand/arm`,
    Mouth.mean          = `mouth/throat`,
    Head.mean           = head,
    Torso.mean          = torso,
    # ===== PERCEPTUAL SD =====
    Visual.SD           = visual_SD,
    Auditory.SD         = auditory_SD,
    Gustatory.SD        = taste_SD,
    Haptic.SD           = tactile_SD,
    Interoceptive.SD    = interoceptive_SD,
    Olfactory.SD        = smell_SD,
    # ===== ACTION SD =====
    Foot_leg.SD         = `leg/foot_SD`,
    Hand_arm.SD         = `hand/arm_SD`,
    Mouth.SD            = `mouth/throat_SD`,
    Head.SD             = head_SD,
    Torso.SD            = torso_SD,
    # ===== SUMMARY VARIABLES =====
    Max_strength.perceptual     = max_perceptual,
    Minkowski3.perceptual       = Minkowski3_perceptual,
    Exclusivity.perceptual      = modality_exclusivity,
    Dominant.perceptual         = dominant_modality,
    Max_strength.action         = max_action,
    Minkowski3.action           = Minkowski3_action,
    Exclusivity.action          = effector_exclusivity,
    Dominant.action             = dominant_effector,
    Max_strength.sensorimotor   = max_sensorimotor,
    Minkowski3.sensorimotor     = Minkowski3_sensorimotor,
    Exclusivity.sensorimotor    = exclusivity_sensorimotor,
    Dominant.sensorimotor       = dominant_sensorimotor
  )

norms <- norms %>%
  select(
    Word, Word_Chinese, traditional, pinyin, pos, radical_1, character_type_1, radical_2, character_type_2,
    Auditory.mean, Gustatory.mean, Haptic.mean, Interoceptive.mean, Olfactory.mean, Visual.mean,
    Foot_leg.mean, Hand_arm.mean, Head.mean, Mouth.mean, Torso.mean,
    Auditory.SD, Gustatory.SD, Haptic.SD, Interoceptive.SD, Olfactory.SD, Visual.SD,
    Foot_leg.SD, Hand_arm.SD, Head.SD, Mouth.SD, Torso.SD,
    everything()
  )

# Guardar archivo
write.csv(norms, "Chinese_sensorimotor_norms.csv", row.names = FALSE)

